# ai-bob-setup-agent — environment configuration
# Copy to .env and fill in. .env is gitignored.
# Run `make doctor` to verify all required keys are present.

# ---------------------------------------------------------------------------
# Operator identity
# ---------------------------------------------------------------------------
BOB_OPERATOR_NAME="Bob Rapp"
BOB_OPERATOR_EMAIL="bobrapp@hotmail.com"
BOB_TIMEZONE="America/Los_Angeles"

# ---------------------------------------------------------------------------
# Orgo — the cloud-computer platform agents run on
# Get keys at: https://www.orgo.ai (or via Nick's onboarding call)
# ---------------------------------------------------------------------------
ORGO_API_KEY=""
ORGO_API_BASE="https://api.orgo.ai/v1"
ORGO_DEFAULT_REGION="us-west-2"

# ---------------------------------------------------------------------------
# Hermes — premium agent runtime ($10K/mo tier)
# ---------------------------------------------------------------------------
HERMES_LICENSE_KEY=""
HERMES_RUNTIME_VERSION="latest"

# ---------------------------------------------------------------------------
# OpenClaw — light-tier agent runtime ($5K/mo tier)
# ---------------------------------------------------------------------------
OPENCLAW_LICENSE_KEY=""

# ---------------------------------------------------------------------------
# Model provider keys
# Use GPT 5.5 as default for tool-calling. GLM 5.1 / Kimmy for cheap light work.
# Opus 4.7 for long-horizon coding agents.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=""           # GPT 5.5
ANTHROPIC_API_KEY=""        # Opus 4.7
ZAI_API_KEY=""              # GLM 5.1
KIMI_API_KEY=""             # Kimmy
DEFAULT_MODEL="gpt-5.5"

# ---------------------------------------------------------------------------
# MCPs — Model Context Protocol servers that give agents live context
# ---------------------------------------------------------------------------
PERPLEXITY_API_KEY=""       # Live web search MCP
CONTEXT7_API_KEY=""         # Live docs MCP
X_MCP_BEARER_TOKEN=""       # X (Twitter) MCP

# ---------------------------------------------------------------------------
# Connectors
# ---------------------------------------------------------------------------
COMPOSIO_API_KEY=""         # App-action connectors
AGENT_MAIL_API_KEY=""       # Email infrastructure for agents
AGENT_MAIL_DOMAIN=""        # e.g. agents.yourdomain.com

# ---------------------------------------------------------------------------
# Telegram — the meta-agent control channel
# Get a bot token from @BotFather. CHAT_ID is your private control chat.
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CONTROL_CHAT_ID=""

# ---------------------------------------------------------------------------
# Observability — email alerts when watchdogs fire
# ---------------------------------------------------------------------------
ALERT_EMAIL_FROM=""
ALERT_EMAIL_TO=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# ---------------------------------------------------------------------------
# Behaviour toggles
# ---------------------------------------------------------------------------
DRY_RUN="false"             # If true, log intended calls without executing
LOG_LEVEL="INFO"            # DEBUG | INFO | WARN | ERROR
WATCHDOG_INTERVAL_SECONDS="300"
