# AIGovOps Bot — environment configuration
# Copy to .env and fill in. .env is gitignored.

# ---------------------------------------------------------------------------
# Core (required)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=""           # From @BotFather
TELEGRAM_BOB_CHAT_ID=""         # Bob's Telegram chat ID
TELEGRAM_KEN_CHAT_ID=""         # Ken's Telegram chat ID (optional)
OPENAI_API_KEY=""               # For GPT-4o-mini (classification + drafting)

# ---------------------------------------------------------------------------
# Email polling (required for auto-classification)
# ---------------------------------------------------------------------------
IMAP_USER="bobrapp@gmail.com"
IMAP_PASSWORD=""                # Gmail app password (16 chars)
IMAP_HOST="imap.gmail.com"
EMAIL_POLL_INTERVAL="300"       # Seconds between polls (default: 5 min)
EMAIL_POLLING_ENABLED="true"

# ---------------------------------------------------------------------------
# Web interface
# ---------------------------------------------------------------------------
WEB_API_TOKEN="aigovops2026"    # Bearer token for web UI + API access

# ---------------------------------------------------------------------------
# Twilio (for WhatsApp + SMS channels)
# Get at: https://console.twilio.com
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""          # Your Twilio number (for SMS)
TWILIO_WHATSAPP_NUMBER=""       # Usually: whatsapp:+14155238886

# ---------------------------------------------------------------------------
# Optional integrations
# ---------------------------------------------------------------------------
GROQ_API_KEY=""                 # Free fast model (Llama 3.1)
PERPLEXITY_API_KEY=""           # Live web search
COMPOSIO_API_KEY=""             # Gmail/Calendar/Asana integrations
CIRCLE_API_KEY=""               # Circle.so community
CIRCLE_COMMUNITY_ID=""

# ---------------------------------------------------------------------------
# Behaviour
# ---------------------------------------------------------------------------
LOG_LEVEL="INFO"
