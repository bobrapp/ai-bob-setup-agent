{
  "name": "Draft Content",
  "description": "Ask the writing agent to draft content about a topic",
  "trigger": "Hey Siri, draft about [topic]",
  "steps": [
    {
      "type": "set_variable",
      "name": "API_URL",
      "value": "https://YOUR_API_URL"
    },
    {
      "type": "set_variable",
      "name": "TOKEN",
      "value": "YOUR_TOKEN"
    },
    {
      "type": "ask_for_input",
      "prompt": "What should I draft about?",
      "input_type": "text",
      "variable": "TOPIC"
    },
    {
      "type": "get_contents_of_url",
      "url": "${API_URL}/api/voice",
      "method": "POST",
      "headers": {
        "Authorization": "Bearer ${TOKEN}",
        "Content-Type": "application/json"
      },
      "body": {
        "command": "draft",
        "params": {"topic": "${TOPIC}"}
      }
    },
    {
      "type": "get_value_for_key",
      "key": "speech"
    },
    {
      "type": "speak_text",
      "text": "${result}"
    }
  ]
}
