# ai-bob-watchdog environment — loaded by systemd EnvironmentFile=
#
# Copy this file to /etc/ai-bob-setup-agent/watchdog.env and fill in
# real values before starting the service:
#
#   sudo mkdir -p /etc/ai-bob-setup-agent
#   sudo cp deploy/ai-bob-watchdog.env /etc/ai-bob-setup-agent/watchdog.env
#   sudo chmod 600 /etc/ai-bob-setup-agent/watchdog.env
#   sudo nano /etc/ai-bob-setup-agent/watchdog.env
#
# This file is NOT committed with real values. Treat it like .env.

# -------------------------------------------------------------------------
# Required — the watchdog cannot start without these
# -------------------------------------------------------------------------

# Orgo API key for polling cloud computer status
ORGO_API_KEY=

# OpenAI key (used by agents, not the watchdog itself — but loaded by config)
OPENAI_API_KEY=

# Telegram bot for operator alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CONTROL_CHAT_ID=

# -------------------------------------------------------------------------
# Optional — email alerts (recommended for production)
# -------------------------------------------------------------------------

# SMTP for email alerts when agents go down
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# -------------------------------------------------------------------------
# Tuning
# -------------------------------------------------------------------------

# How often the watchdog polls (seconds). Default: 300 (5 min).
# Lower = faster detection, more API calls.
# Recommended: 60 for <5 customers, 300 for 5-20, 600 for 20+.
WATCHDOG_INTERVAL_SECONDS=300
